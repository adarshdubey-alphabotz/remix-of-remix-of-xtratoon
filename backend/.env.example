# ═══════════════════════════════════════════════
# Telegram MTProto Credentials
# ═══════════════════════════════════════════════
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Channel ID where files are stored (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ═══════════════════════════════════════════════
# Supabase (for DB lookups)
# ═══════════════════════════════════════════════
SUPABASE_URL=https://lpozkutezttxiwafhwul.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ═══════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════
PORT=3001
# Comma-separated allowed origins
CORS_ORIGINS=https://glassy-ink-verse.vercel.app,https://xtratoon.com,http://localhost:5173

# ═══════════════════════════════════════════════
# Session (generated after running: npm run auth)
# ═══════════════════════════════════════════════
TELEGRAM_SESSION=
