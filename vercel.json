{
  "rewrites": [
    {
      "source": "/api/img",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/functions/v1/telegram-proxy"
    },
    {
      "source": "/stremio/:path*",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/functions/v1/stremio-addon/:path*"
    },
    {
      "source": "/rest/v1/:path*",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/rest/v1/:path*"
    },
    {
      "source": "/auth/v1/:path*",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/auth/v1/:path*"
    },
    {
      "source": "/storage/v1/:path*",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/storage/v1/:path*"
    },
    {
      "source": "/functions/v1/:path*",
      "destination": "https://nyynuigabiwfgvwvjrvh.supabase.co/functions/v1/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    }
  ]
}